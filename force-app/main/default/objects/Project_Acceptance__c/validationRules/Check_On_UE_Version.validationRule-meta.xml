<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Check_On_UE_Version</fullName>
    <active>false</active>
    <errorConditionFormula>if( Not(IsBlank( Uploaded_UEVersion__c))&amp;&amp;  Uploaded_UEVersion__c != UEVersion__c ,true,false)</errorConditionFormula>
