<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Being_Mandatory_for_Update</fullName>
    <active>true</active>
    <errorConditionFormula>AND (
!ISNEW(),
ISCHANGED(Category__c),
ISBLANK(Project_Management_Director__c)
)</errorConditionFormula>
    <errorMessage>Project Management Director is Mandatory field.</errorMessage>
</ValidationRule>
